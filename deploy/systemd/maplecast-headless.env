# MapleCast headless flycast server — operator-editable env.
#
# Install location: /etc/maplecast/headless.env
# Owned by root, readable by the maplecast user.
#
# This file is loaded by the maplecast-headless.service systemd unit.
# Any var here overrides the in-unit defaults.

# Required: enable MapleCast stacks (input, telemetry, audio).
MAPLECAST=1

# Required: TA mirror server mode (headless deploys should never run the
# legacy H.264 path).
MAPLECAST_MIRROR_SERVER=1

# Required on runtime-gate builds (Phase 1). Harmless on compile-out
# builds (Phase 3) — the binary is already headless.
MAPLECAST_HEADLESS=1

# Ports. Defaults match nobd.net prod.
MAPLECAST_PORT=7100
MAPLECAST_SERVER_PORT=7200

# ROM path. Must be readable by the maplecast user.
MAPLECAST_ROM=/opt/maplecast/roms/mvc2.gdi

# Optional: stick registration persistence. Defaults to $HOME/.maplecast.
# XDG_CONFIG_HOME=/opt/maplecast/cfg
